{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/dora56/dotnet-coupling/main/schemas/dotnet-coupling-report-0.1.schema.json",
  "title": "dotnet-coupling report",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "tool",
    "version",
    "analysis",
    "grade",
    "scores",
    "issueCounts",
    "issues",
    "manifest"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "0.1"
    },
    "tool": {
      "const": "dotnet-coupling"
    },
    "version": {
      "type": "string"
    },
    "analysis": {
      "type": "object",
      "required": [
        "path",
        "mode",
        "files",
        "components",
        "couplings",
        "gitUsed",
        "gitMonths"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "mode": {
          "enum": [
            "syntax-only",
            "semantic-preview"
          ]
        },
        "files": {
          "type": "integer",
          "minimum": 0
        },
        "components": {
          "type": "integer",
          "minimum": 0
        },
        "couplings": {
          "$ref": "#/$defs/couplingCounts"
        },
        "gitUsed": {
          "type": "boolean"
        },
        "gitMonths": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "grade": {
      "type": "object",
      "required": [
        "letter",
        "display",
        "basis",
        "rationale"
      ],
      "properties": {
        "letter": {
          "enum": [
            "S",
            "A",
            "B",
            "C",
            "D",
            "F"
          ]
        },
        "display": {
          "type": "string"
        },
        "basis": {
          "const": "issue-density"
        },
        "rationale": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "scores": {
      "type": "object",
      "required": [
        "averageBalanceScore"
      ],
      "properties": {
        "averageBalanceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "issueCounts": {
      "$ref": "#/$defs/issueCounts"
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "projectModel": {
      "$ref": "#/$defs/projectModel"
    },
    "manifest": {
      "type": "object",
      "required": [
        "confidence",
        "runNotes",
        "blindSpots"
      ],
      "properties": {
        "confidence": {
          "enum": [
            "syntax-only",
            "semantic-preview"
          ]
        },
        "runNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blindSpots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/blindSpot"
          }
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnostic"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "couplingCounts": {
      "type": "object",
      "required": [
        "total",
        "internal",
        "external"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "internal": {
          "type": "integer",
          "minimum": 0
        },
        "external": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "issueCounts": {
      "type": "object",
      "required": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "properties": {
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
      "required": [
        "type",
        "severity",
        "source",
        "target",
        "score",
        "problem",
        "recommendation",
        "location"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "severity": {
          "enum": [
            "Low",
            "Medium",
            "High",
            "Critical"
          ]
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "problem": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "location": {
          "anyOf": [
            {
              "$ref": "#/$defs/location"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "location": {
      "type": "object",
      "required": [
        "file",
        "line"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "blindSpot": {
      "type": "object",
      "required": [
        "kind",
        "description"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": [
        "code",
        "severity",
        "message",
        "path"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "projectModel": {
      "type": "object",
      "required": [
        "projectCount",
        "projects"
      ],
      "properties": {
        "projectCount": {
          "type": "integer",
          "minimum": 0
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectMetadataEntry"
          }
        }
      },
      "additionalProperties": false
    },
    "projectMetadataEntry": {
      "type": "object",
      "required": [
        "projectPath",
        "projectName",
        "assemblyName",
        "sourceFileCount",
        "projectReferences",
        "packageReferences"
      ],
      "properties": {
        "projectPath": {
          "type": "string"
        },
        "projectName": {
          "type": "string"
        },
        "assemblyName": {
          "type": "string"
        },
        "sourceFileCount": {
          "type": "integer",
          "minimum": 0
        },
        "projectReferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packageReferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
